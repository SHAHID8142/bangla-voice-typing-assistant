{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bangla-voice-typing-assistant",
  "version": "0.1.0",
  "identifier": "com.maryam.bangla-voice-typing-assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOS": {
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Bangla Voice Typing Assistant needs access to your microphone to transcribe your speech to text.",
        "NSSpeechRecognitionUsageDescription": "Bangla Voice Typing Assistant needs access to speech recognition."
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "Bangla Voice Typing Assistant",
        "width": 1000,
        "height": 800
      },
      {
        "label": "overlay",
        "title": "Dictation Overlay",
        "width": 320,
        "height": 180,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
